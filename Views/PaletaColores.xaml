<Window x:Class="KalebClipPro.Views.PaletaColores"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paleta" SizeToContent="WidthAndHeight" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Deactivated="Window_Deactivated">

    <Border Background="#1E1E1E" CornerRadius="8" BorderBrush="#3E3E42" BorderThickness="1" Margin="10" Padding="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" Opacity="0.5" ShadowDepth="4"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="150"/>  <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <Border CornerRadius="4" ClipToBounds="True" BorderBrush="#3E3E42" BorderThickness="1">
                    <Grid x:Name="ColorCanvas" Background="Transparent" MouseDown="ColorCanvas_MouseDown" MouseMove="ColorCanvas_MouseMove" MouseUp="ColorCanvas_MouseUp">
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF0000" Offset="0.0"/>
                                    <GradientStop Color="#FFFF00" Offset="0.16"/>
                                    <GradientStop Color="#00FF00" Offset="0.33"/>
                                    <GradientStop Color="#00FFFF" Offset="0.50"/>
                                    <GradientStop Color="#0000FF" Offset="0.66"/>
                                    <GradientStop Color="#FF00FF" Offset="0.83"/>
                                    <GradientStop Color="#FF0000" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Ellipse x:Name="CursorColor" Width="10" Height="10" Stroke="Black" StrokeThickness="2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-5,-5,0,0" IsHitTestVisible="False">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="2" ShadowDepth="1" Color="White"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="15"/> 
                        <ColumnDefinition Width="15"/> 
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="4" BorderBrush="#3E3E42" BorderThickness="1">
                        <Rectangle RadiusX="3" RadiusY="3">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="White" Offset="0"/>
                                    <GradientStop x:Name="ColorPuroGradient" Color="Red" Offset="0.5"/>
                                    <GradientStop Color="Black" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </Border>

                    <Slider Grid.ColumnSpan="2" x:Name="SliderLuminosidad" Orientation="Vertical" Minimum="0" Maximum="1" Value="0.5" 
                            ValueChanged="SliderLuminosidad_ValueChanged" Background="Transparent" BorderThickness="0" IsMoveToPointEnabled="True"
                            SmallChange="0.01" LargeChange="0.01" FocusVisualStyle="{x:Null}" PreviewMouseLeftButtonDown="SliderLuminosidad_PreviewMouseDown" PreviewMouseMove="SliderLuminosidad_PreviewMouseMove" PreviewMouseLeftButtonUp="SliderLuminosidad_PreviewMouseUp">
                        <Slider.Template>
                            <ControlTemplate TargetType="Slider">
                                <Grid>
                                    <Track x:Name="PART_Track">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="Slider.DecreaseLarge">
                                                <RepeatButton.Template>
                                                    <ControlTemplate TargetType="RepeatButton">
                                                        <Border Background="Transparent"/>
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.DecreaseRepeatButton>
                                        
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="Slider.IncreaseLarge">
                                                <RepeatButton.Template>
                                                    <ControlTemplate TargetType="RepeatButton">
                                                        <Border Background="Transparent"/>
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.IncreaseRepeatButton>
                                        
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Path Data="M 8,0 L 0,5 L 8,10 Z" Fill="White" Width="8" Height="10" HorizontalAlignment="Right" Margin="0,0,2,0">
                                                            <Path.Effect>
                                                                <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.8"/>
                                                            </Path.Effect>
                                                        </Path>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Slider.Template>
                    </Slider>
                </Grid>
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,15,0,10" HorizontalAlignment="Center">
                <TextBlock Text="R:" Foreground="#AAA" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtR" TextChanged="TxtRGB_TextChanged" Width="30" Margin="5,0,10,0" Background="#2D2D30" Foreground="White" CaretBrush="White" BorderBrush="#3E3E42"/>
                <TextBlock Text="G:" Foreground="#AAA" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtG" TextChanged="TxtRGB_TextChanged" Width="30" Margin="5,0,10,0" Background="#2D2D30" Foreground="White" CaretBrush="White" BorderBrush="#3E3E42"/>
                <TextBlock Text="B:" Foreground="#AAA" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtB" TextChanged="TxtRGB_TextChanged" Width="30" Margin="5,0,10,0" Background="#2D2D30" Foreground="White" CaretBrush="White" BorderBrush="#3E3E42"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15" HorizontalAlignment="Center">
                <TextBlock Text="Hex:" Foreground="#AAA" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtHex" TextChanged="TxtHex_TextChanged" Width="70" Margin="5,0,15,0" Background="#2D2D30" Foreground="White" CaretBrush="White" BorderBrush="#3E3E42" FontFamily="Consolas"/>
                <Border x:Name="BrdVistaPrevia" Width="26" Height="26" CornerRadius="4" Background="White" BorderBrush="#555" BorderThickness="1"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,5,0,15">
                <TextBlock Text="Básicos" Foreground="#7A848F" FontSize="11" Margin="5,0,0,5" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Border Width="20" Height="20" CornerRadius="10" Background="#F44336" Margin="0,0,8,0" Cursor="Hand" MouseLeftButtonDown="Swatch_Click" ToolTip="Rojo"/>
                    <Border Width="20" Height="20" CornerRadius="10" Background="#FF9800" Margin="0,0,8,0" Cursor="Hand" MouseLeftButtonDown="Swatch_Click" ToolTip="Naranja"/>
                    <Border Width="20" Height="20" CornerRadius="10" Background="#FFEB3B" Margin="0,0,8,0" Cursor="Hand" MouseLeftButtonDown="Swatch_Click" ToolTip="Amarillo"/>
                    <Border Width="20" Height="20" CornerRadius="10" Background="#4CAF50" Margin="0,0,8,0" Cursor="Hand" MouseLeftButtonDown="Swatch_Click" ToolTip="Verde"/>
                    <Border Width="20" Height="20" CornerRadius="10" Background="#00ADB5" Margin="0,0,8,0" Cursor="Hand" MouseLeftButtonDown="Swatch_Click" ToolTip="Cian (Acento)"/>
                    <Border Width="20" Height="20" CornerRadius="10" Background="#2196F3" Margin="0,0,8,0" Cursor="Hand" MouseLeftButtonDown="Swatch_Click" ToolTip="Azul"/>
                    <Border Width="20" Height="20" CornerRadius="10" Background="#9C27B0" Margin="0,0,8,0" Cursor="Hand" MouseLeftButtonDown="Swatch_Click" ToolTip="Morado"/>
                    <Border Width="20" Height="20" CornerRadius="10" Background="#E0E0E0" Margin="0,0,0,0" Cursor="Hand" MouseLeftButtonDown="Swatch_Click" ToolTip="Gris Claro"/>
                </StackPanel>

                <TextBlock Text="Recientes" Foreground="#7A848F" FontSize="11" Margin="5,0,0,5" FontWeight="SemiBold"/>
                <StackPanel x:Name="PanelRecientes" Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,0,0,0" Height="20">
                    </StackPanel>
            </StackPanel>

            <Button Grid.Row="4" Content="Aplicar Color" Background="#007ACC" Foreground="White" BorderThickness="0" Padding="0,8" Cursor="Hand" Click="BtnAplicar_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
            
        </Grid>
    </Border>
</Window>