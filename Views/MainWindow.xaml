                                <Button Focusable="False" Click="BtnMdLink_Click" Style="{StaticResource SidebarIconButtonStyle}" Height="20" Width="20" Margin="4,0"><Path Data="M3.9,12C3.9,10.29 5.29,8.9 7,8.9H11V7H7A5,5 0 0,0 2,12A5,5 0 0,0 7,17H11V15.1H7C5.29,15.1 3.9,13.71 3.9,12M8,13H16V11H8V13M17,7H13V8.9H17C18.71,8.9 20.1,10.29 20.1,12C20.1,13.71 18.71,15.1 17,15.1H13V17H17A5,5 0 0,0 22,12A5,5 0 0,0 17,7Z" Fill="{StaticResource TextMuted}" Stretch="Uniform" Height="11"/></Button>
                                <Button Focusable="False" Click="BtnMdTable_Click" Style="{StaticResource SidebarIconButtonStyle}" Height="20" Width="20" Margin="4,0"><Path Data="M5,4H19A2,2 0 0,1 21,6V18A2,2 0 0,1 19,20H5A2,2 0 0,1 3,18V6A2,2 0 0,1 5,4M5,8V12H11V8H5M13,8V12H19V8H13M5,14V18H11V14H5M13,14V18H19V14H13Z" Fill="{StaticResource TextMuted}" Stretch="Uniform" Height="11"/></Button>
                                <Button Focusable="False" Click="BtnMdMath_Click" Style="{StaticResource SidebarIconButtonStyle}" Height="20" Width="20" Margin="4,0"><Path Data="M18,6H16V4H7V7.12L12,12L7,16.88V20H16V18H9.36L13.5,14L18,18.41V20.5L12,14.65L6,20.5V16L10.66,11.5L6,7V2.5H18V6Z" Fill="{StaticResource TextMuted}" Stretch="Uniform" Height="11"/></Button>
                            </UniformGrid>
                            <Button Focusable="False" x:Name="BtnMenuInsert" Click="BtnMenuInsert_Click" Width="30" Height="22" Background="Transparent" BorderThickness="0" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="#A0ABBA" Stretch="Uniform" Height="10"/><Path Data="M7,10L12,15L17,10H7Z" Fill="#A0ABBA" Stretch="Uniform" Height="3" Margin="3,0,0,0"/></StackPanel>
                            </Button>
                            <Popup x:Name="PopInsert" PlacementTarget="{Binding ElementName=BtnMenuInsert}" StaysOpen="False" AllowsTransparency="True"><Border Background="#252B32" BorderBrush="#3A444D" BorderThickness="1" CornerRadius="4" Padding="2"><StackPanel><Button Click="BtnMdQuote_Click" Style="{StaticResource SidebarIconButtonStyle}" Width="24" Height="24" Margin="2"><Path Data="M14,17H17L19,13V7H13V13H16M6,17H9L11,13V7H5V13H8L6,17Z" Fill="{StaticResource TextMuted}" Stretch="Uniform" Height="10"/></Button><Button Click="BtnMdCode_Click" Style="{StaticResource SidebarIconButtonStyle}" Width="24" Height="24" Margin="2"><Path Data="M14.6,16.6L19.2,12L14.6,7.4L16,6L22,12L16,18L14.6,16.6M9.4,16.6L4.8,12L9.4,7.4L8,6L2,12L8,18L9.4,16.6Z" Fill="{StaticResource TextMuted}" Stretch="Uniform" Height="11"/></Button><Button Click="BtnMdLink_Click" Style="{StaticResource SidebarIconButtonStyle}" Width="24" Height="24" Margin="2"><Path Data="M3.9,12C3.9,10.29 5.29,8.9 7,8.9H11V7H7A5,5 0 0,0 2,12A5,5 0 0,0 7,17H11V15.1H7C5.29,15.1 3.9,13.71 3.9,12M8,13H16V11H8V13M17,7H13V8.9H17C18.71,8.9 20.1,10.29 20.1,12C20.1,13.71 18.71,15.1 17,15.1H13V17H17A5,5 0 0,0 22,12A5,5 0 0,0 17,7Z" Fill="{StaticResource TextMuted}" Stretch="Uniform" Height="11"/></Button><Button Click="BtnMdTable_Click" Style="{StaticResource SidebarIconButtonStyle}" Width="24" Height="24" Margin="2"><Path Data="M5,4H19A2,2 0 0,1 21,6V18A2,2 0 0,1 19,20H5A2,2 0 0,1 3,18V6A2,2 0 0,1 5,4M5,8V12H11V8H5M13,8V12H19V8H13M5,14V18H11V14H5M13,14V18H19V14H13Z" Fill="{StaticResource TextMuted}" Stretch="Uniform" Height="11"/></Button><Button Click="BtnMdMath_Click" Style="{StaticResource SidebarIconButtonStyle}" Width="24" Height="24" Margin="2"><Path Data="M18,6H16V4H7V7.12L12,12L7,16.88V20H16V18H9.36L13.5,14L18,18.41V20.5L12,14.65L6,20.5V16L10.66,11.5L6,7V2.5H18V6Z" Fill="{StaticResource TextMuted}" Stretch="Uniform" Height="11"/></Button></StackPanel></Border></Popup>
                        </Grid>

                    </Grid>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="2" Panel.ZIndex="0" Background="{StaticResource CardBg}" BorderBrush="#252B32" BorderThickness="1,0,0,0" CornerRadius="0" ClipToBounds="True">
                <Grid>
                    <Grid x:Name="TextBoxContainer" Margin="0"/>

                    <Grid x:Name="RecolectorContainer" Margin="0" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="15,8,15,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/>    <ColumnDefinition Width="Auto"/> </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="WORKFLOW:" Foreground="#5A6575" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0"/>

                            <Border Grid.Column="1" Background="#2D333B" CornerRadius="15" Padding="2" HorizontalAlignment="Left" Margin="0,0,15,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/>    <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> </Grid.ColumnDefinitions>

                                    <RepeatButton Grid.Column="0" x:Name="BtnScrollIzq" Click="BtnScrollIzq_Click" Delay="150" Interval="40" Width="18" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Desplazar a la izquierda">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border x:Name="Bg" Background="Transparent" CornerRadius="13,0,0,13">
                                                    <Path x:Name="Icon" Data="M14,7L9,12L14,17V7Z" Fill="#5A6575" Stretch="Uniform" Height="8"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bg" Property="Background" Value="#3A444D"/>
                                                        <Setter TargetName="Icon" Property="Fill" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>

                                    <ScrollViewer Grid.Column="1" x:Name="ScrollSets" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" PanningMode="HorizontalOnly">
                                        <StackPanel x:Name="ContenedorSets" Orientation="Horizontal">
                                            <RadioButton Content="Set 1" Tag="1" IsChecked="True" Click="BtnCambiarSet_Click" Style="{StaticResource SegmentedButtonStyle}"/>
                                            <RadioButton Content="Set 2" Tag="2" Click="BtnCambiarSet_Click" Style="{StaticResource SegmentedButtonStyle}"/>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <RepeatButton Grid.Column="2" x:Name="BtnScrollDer" Click="BtnScrollDer_Click" Delay="150" Interval="40" Width="18" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Desplazar a la derecha">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border x:Name="Bg" Background="Transparent" CornerRadius="0">
                                                    <Path x:Name="Icon" Data="M10,17L15,12L10,7V17Z" Fill="#5A6575" Stretch="Uniform" Height="8"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bg" Property="Background" Value="#3A444D"/>
                                                        <Setter TargetName="Icon" Property="Fill" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>

                                    <Border Grid.Column="3" Width="1" Background="#4A535F" Margin="4,4" CornerRadius="0.5"/>
                                    <Button Grid.Column="4" x:Name="BtnAgregarSet" Click="BtnAgregarSet_Click" Style="{StaticResource AddSetButtonStyle}" ToolTip="Añadir nuevo Set"/>
                                    <Button Grid.Column="5" x:Name="BtnQuitarSet" Click="BtnQuitarSet_Click" Style="{StaticResource RemoveSetButtonStyle}" ToolTip="Quitar el último Set"/>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                
                                <Border Background="#2D333B" CornerRadius="4" Padding="2" Margin="0,0,15,0">
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="BtnVistaLista" GroupName="GrupoVistas" Content="≡ Lista" IsChecked="True" Style="{StaticResource SegmentedButtonStyle}" FontSize="10" Padding="8,4"/>
                                        <RadioButton x:Name="BtnVistaIconos" GroupName="GrupoVistas" Content="⊞ Iconos" Style="{StaticResource SegmentedButtonStyle}" FontSize="10" Padding="8,4"/>
                                    </StackPanel>
                                </Border>

                                <Button x:Name="BtnGuardarWorkflow" ToolTip="Forzar guardado del Workflow" 
                                        Foreground="White" Margin="0,0,8,0" Cursor="Hand" FontWeight="SemiBold"
                                        FocusVisualStyle="{x:Null}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bg" Background="#00ADB5" CornerRadius="4" Padding="10,4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="Guardar"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="#00C4CC"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button x:Name="BtnLimpiar" Click="BtnLimpiarRecolector_Click" Style="{StaticResource CleanSlotsButtonStyle}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            </StackPanel>
                        </Grid>

                        <ListBox x:Name="ListaRecolector" Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="0,0,0,15" 
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 FocusVisualStyle="{x:Null}"
                                 PreviewMouseWheel="ListaRecolector_PreviewMouseWheel"
                                 dd:DragDrop.IsDragSource="True"
                                 dd:DragDrop.IsDropTarget="True"
                                 dd:DragDrop.DropHandler="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                 dd:DragDrop.UseDefaultDragAdorner="False">
                            
                            <ListBox.LayoutTransform>
                                <ScaleTransform x:Name="ZoomTransform" ScaleX="1.0" ScaleY="1.0"/>
                            </ListBox.LayoutTransform>

                            <dd:DragDrop.DragAdornerTemplate>
                                <DataTemplate>
                                    <Grid Width="{Binding ActualWidth, Source={x:Reference ListaRecolector}}">
                                        <Border Margin="15,0,15,10" Background="#252B32" BorderBrush="#FFD700" BorderThickness="1" CornerRadius="8" Opacity="0.8" Padding="12" SnapsToDevicePixels="True">
                                            <Grid>
                                                <StackPanel>
                                                    <Border Background="#33FFD700" BorderBrush="#FFD700" BorderThickness="1" CornerRadius="3" HorizontalAlignment="Left" Padding="5,2" Margin="0,0,0,8">
                                                        <TextBlock Text="{Binding HotKeyIndex, StringFormat='Moviendo Slot {0}...'}" Foreground="#FFD700" FontSize="10" FontWeight="Bold" FontFamily="Consolas"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Contenido_Plano}" Foreground="#E8ECEF" FontSize="11" FontFamily="Consolas" MaxHeight="32" TextTrimming="CharacterEllipsis" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </dd:DragDrop.DragAdornerTemplate>

                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="ItemTemplate" Value="{StaticResource TemplateVistaLista}"/>
                                    <Setter Property="ItemsPanel" Value="{StaticResource PanelVistaLista}"/>
                                    <Setter Property="ItemContainerStyle" Value="{StaticResource ContainerVistaLista}"/>
                                    
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, ElementName=BtnVistaIconos}" Value="True">
                                            <Setter Property="ItemTemplate" Value="{StaticResource TemplateVistaIconos}"/>
                                            <Setter Property="ItemsPanel" Value="{StaticResource PanelVistaIconos}"/>
                                            <Setter Property="ItemContainerStyle" Value="{StaticResource ContainerVistaIconos}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>