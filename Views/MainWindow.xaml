                        </Grid>

                        <Border Grid.Column="7" Width="1" Height="12" Background="#3A444D" HorizontalAlignment="Center"/>

                        <Grid Grid.Column="8">
                            <UniformGrid x:Name="GrpInsertFull" Columns="5" VerticalAlignment="Center">
                                <Button Focusable="False" Click="BtnMdQuote_Click" Style="{StaticResource SidebarIconButtonStyle}" Height="20" Width="20" Margin="4,0"><Path Data="M14,17H17L19,13V7H13V13H16M6,17H9L11,13V7H5V13H8L6,17Z" Fill="{StaticResource TextMuted}" Stretch="Uniform" Height="10"/></Button>
