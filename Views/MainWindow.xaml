<Window x:Class="KalebClipPro.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dd="urn:gong-wpf-dragdrop"
    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
    xmlns:infra="clr-namespace:KalebClipPro.Infrastructure"
    xmlns:local="clr-namespace:KalebClipPro"
    xmlns:views="clr-namespace:KalebClipPro.Views"
    Title="Kaleb-Clip Pro" Height="700" Width="1100"
    Background="#1D2227" Foreground="#E8ECEF"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="ComboBoxTransparentButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="templateRoot" Background="#252B32" BorderBrush="#3A444D" BorderThickness="1" CornerRadius="2">
                            <Path x:Name="arrow" Data="M0,0 L4,4 L8,0 Z" Fill="#A0ABBA" HorizontalAlignment="Right" Margin="0,0,5,0" VerticalAlignment="Center" Stretch="Uniform" Height="4"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="templateRoot" Property="Background" Value="#3A444D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxFinal" TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="#252B32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/> 
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid x:Name="templateRoot">
                            <ToggleButton x:Name="toggleButton" Grid.ColumnSpan="2" 
                                          Style="{StaticResource ComboBoxTransparentButtonStyle}" 
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            
                            <ContentPresenter x:Name="contentPresenter" 
                                              Content="{TemplateBinding SelectionBoxItem}" 
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="5,0,20,0" IsHitTestVisible="false"/>

                            <Popup x:Name="PART_Popup" AllowsTransparency="true" 
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" 
                                   Placement="Bottom" PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder" Background="#252B32" BorderBrush="#3A444D" 
                                        BorderThickness="1" Width="{Binding ActualWidth, ElementName=templateRoot}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer x:Name="DropDownScrollViewer">
                                        <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxItemFinal" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Padding" Value="0,3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="Bd" Background="Transparent" SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center" Margin="5,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A444D"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D2227"/>
                                <Setter Property="Foreground" Value="#00D4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="SubmenuOscuroTemplate" TargetType="MenuItem">
            <Border x:Name="Border" Background="{TemplateBinding Background}" BorderThickness="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="24"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/> </Grid.ColumnDefinitions>
                    
                    <ContentPresenter ContentSource="Icon" Margin="5,0,5,0" VerticalAlignment="Center" />
                    <ContentPresenter Grid.Column="1" ContentSource="Header" Margin="5,5,15,5" VerticalAlignment="Center"/>
                    <Path x:Name="RightArrow" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,5,0" Fill="#A0ABBA" Data="M0,0 L4,4 L0,8 Z" Visibility="Collapsed"/>
                    
                    <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Right" IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" Focusable="False" PopupAnimation="Fade">
                        <Border Background="#252B32" BorderBrush="#3A444D" BorderThickness="1" CornerRadius="4" Margin="0,0,5,5">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="5" Opacity="0.3" ShadowDepth="3"/>
                            </Border.Effect>
                            <ScrollViewer>
                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                            </ScrollViewer>
                        </Border>
                    </Popup>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="Role" Value="SubmenuHeader">
                    <Setter TargetName="RightArrow" Property="Visibility" Value="Visible"/>
                </Trigger>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#00ADB5"/> <Setter TargetName="RightArrow" Property="Fill" Value="White"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="MenuItemSubmenuOscuro" TargetType="MenuItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template" Value="{StaticResource SubmenuOscuroTemplate}"/>
        </Style>

        <ItemsPanelTemplate x:Key="PanelVistaLista">
            <VirtualizingStackPanel Orientation="Vertical"/>
        </ItemsPanelTemplate>

        <ItemsPanelTemplate x:Key="PanelVistaIconos">
            <WrapPanel Orientation="Horizontal" IsItemsHost="True"/>
        </ItemsPanelTemplate>

        <Style x:Key="ContainerVistaLista" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="15,0,15,10"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ContainerVistaIconos" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,15,15"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="Transparent">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="TemplateVistaIconos">
            <Border x:Name="CardBorder" Width="180" Height="140" Background="{StaticResource TextCardBg}" CornerRadius="8" BorderThickness="1" BorderBrush="#1D2227" dd:DragDrop.DragSourceIgnore="True"> 
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="30"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border x:Name="HeaderBg" Grid.Row="0" Background="#1A000000" CornerRadius="8,8,0,0" SnapsToDevicePixels="True">
                        <Grid Margin="10,0">
                            <Border x:Name="SlotBadge" Background="#33FFD700" BorderBrush="#FFD700" BorderThickness="1" CornerRadius="3" Height="18" HorizontalAlignment="Left" VerticalAlignment="Center" Padding="6,0">
                                <TextBlock Text="{Binding HotKeyIndex, StringFormat='Slot {0}'}" Foreground="#FFD700" FontSize="10" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel x:Name="ActionButtons" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Style="{StaticResource SidebarIconButtonStyle}" Click="BtnCopiarSlot_Click" Width="20" Height="20" Margin="0,0,4,0"><Path Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z" Fill="#5A6575" Stretch="Uniform" Height="10"/></Button>
                                <Button Style="{StaticResource DeleteIconButtonStyle}" Click="BtnEliminarSlot_Click" Width="20" Height="20"><Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="#5A6575" Stretch="Uniform" Height="10"/></Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1" Margin="10">
                        <TextBlock x:Name="TxtAppName" Text="{Binding Origen_App}" Foreground="#00BFA5" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Bottom" Opacity="0.6"/>
                        <TextBlock x:Name="PlaceholderTxt" Text="(Vacío)" Foreground="#444444" FontStyle="Italic" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                        <TextBox x:Name="TxtContenido" Text="{Binding Contenido_Plano, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="{StaticResource TextMain}" BorderThickness="0" TextWrapping="Wrap" AcceptsReturn="True" FontFamily="Consolas" FontSize="11" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"/>
                    </Grid>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding EsVacio}" Value="True">
                    <Setter TargetName="CardBorder" Property="Background" Value="#0DFFFFFF"/>
                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="#1AFFFFFF"/>
                    <Setter TargetName="SlotBadge" Property="Background" Value="Transparent"/>
                    <Setter TargetName="SlotBadge" Property="BorderBrush" Value="#33FFFFFF"/>
                    <Setter TargetName="ActionButtons" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="PlaceholderTxt" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding EsVacio}" Value="False"><Setter TargetName="CardBorder" Property="BorderBrush" Value="#FFD700"/></DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="TemplateVistaLista">
            <Grid>
                <Border x:Name="CardBorder" Background="{StaticResource TextCardBg}" CornerRadius="8" BorderThickness="1" BorderBrush="#1D2227" dd:DragDrop.DragSourceIgnore="True"> 
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="25"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Border x:Name="HeaderBg" Grid.Row="0" Background="#1A000000" CornerRadius="8,8,0,0" Height="25" SnapsToDevicePixels="True">
                            <Grid Margin="35,0,10,0">
                                <Border x:Name="SlotBadge" Background="#33FFD700" BorderBrush="#FFD700" BorderThickness="1" CornerRadius="3" Height="18" HorizontalAlignment="Left" VerticalAlignment="Center" SnapsToDevicePixels="True">
                                    <TextBlock x:Name="TxtSlotHeader" Text="{Binding HotKeyIndex, StringFormat='Slot {0}'}" Foreground="#FFD700" FontSize="10" FontWeight="Bold" FontFamily="Consolas" Margin="6,0" VerticalAlignment="Center" HorizontalAlignment="Center" SnapsToDevicePixels="True"/>
                                </Border>
                                <StackPanel x:Name="ActionButtons" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtAppName" Text="{Binding Origen_App}" Foreground="#5A6575" FontSize="9" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center" Opacity="0.8"/>
                                    <Button Style="{StaticResource SidebarIconButtonStyle}" Click="BtnCopiarSlot_Click" Width="22" Height="22" Margin="0,0,2,0"><Path Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z" Fill="#5A6575" Stretch="Uniform" Height="11"/></Button>
                                    <Button Style="{StaticResource DeleteIconButtonStyle}" Click="BtnEliminarSlot_Click" Width="22" Height="22"><Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="#5A6575" Stretch="Uniform" Height="11"/></Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Grid Grid.Row="1">
                            <TextBlock x:Name="PlaceholderTxt" Text="(Slot Vacío)" Foreground="#444444" FontStyle="Italic" FontFamily="Consolas" FontSize="12" Margin="14,10" Visibility="Collapsed" IsHitTestVisible="False"/>
                            <TextBox x:Name="TxtContenido" Text="{Binding Contenido_Plano, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="{Binding AlturaVisual}" Background="Transparent" Foreground="{StaticResource TextMain}" BorderThickness="0" Padding="12,8,12,5" TextWrapping="Wrap" AcceptsReturn="True" FontFamily="Consolas" FontSize="13" VerticalScrollBarVisibility="Auto"/>
                        </Grid>
                        <Thumb x:Name="ResizerThumb" Grid.Row="2" Cursor="SizeNS" DragDelta="BlockResizer_DragDelta" ToolTip="Ajustar altura" Background="Transparent" Height="12">
                            <Thumb.Template><ControlTemplate TargetType="Thumb"><Border Background="Transparent" VerticalAlignment="Stretch"><Border Height="3" Width="30" Background="#3A444D" CornerRadius="1.5" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,4"/></Border></ControlTemplate></Thumb.Template>
                        </Thumb>
                    </Grid>
                </Border>
                <Border x:Name="DragGrip" HorizontalAlignment="Left" VerticalAlignment="Top" Width="30" Height="25" Background="Transparent" Cursor="SizeNS" ToolTip="Arrastrar para mover">
                    <Path Data="M9,3H11V5H9V3M13,3H15V5H13V3M9,7H11V9H9V7M13,7H15V9H13V7M9,11H11V13H9V11M13,11H15V13H13V11M9,15H11V17H9V15M13,15H15V17H13V15M9,19H11V21H9V19M13,19H15V21H13V19Z" Fill="#5A6575" Stretch="Uniform" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding EsVacio}" Value="True">
                    <Setter TargetName="CardBorder" Property="Background" Value="#0DFFFFFF"/>
                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="#1AFFFFFF"/>
                    <Setter TargetName="HeaderBg" Property="Background" Value="#0A000000"/>
                    <Setter TargetName="SlotBadge" Property="Background" Value="Transparent"/>
                    <Setter TargetName="SlotBadge" Property="BorderBrush" Value="#33FFFFFF"/>
                    <Setter TargetName="TxtSlotHeader" Property="Foreground" Value="#555555"/>
                    <Setter TargetName="ActionButtons" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="DragGrip" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ResizerThumb" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="PlaceholderTxt" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding EsVacio}" Value="False"><Setter TargetName="CardBorder" Property="BorderBrush" Value="#FFD700"/></DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions><Condition Binding="{Binding EsVacio}" Value="False"/><Condition Binding="{Binding Contenido_Plano, Converter={StaticResource ClipCategoryConverter}}" Value="Code"/></MultiDataTrigger.Conditions>
                    <Setter TargetName="CardBorder" Property="Background" Value="{StaticResource CodeCardBg}"/>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions><Condition Binding="{Binding EsVacio}" Value="False"/><Condition Binding="{Binding Contenido_Plano, Converter={StaticResource ClipCategoryConverter}}" Value="Url"/></MultiDataTrigger.Conditions>
                    <Setter TargetName="CardBorder" Property="Background" Value="{StaticResource UrlCardBg}"/>
                </MultiDataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="35"/> 
            <ColumnDefinition x:Name="SidebarColumn" Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#181D21" BorderBrush="#252B32" BorderThickness="0,0,1,0" Panel.ZIndex="10">
            <StackPanel Margin="0,15,0,0">
                <RadioButton x:Name="TabEditor" GroupName="MainMenu" Style="{StaticResource SidebarNavButtonStyle}" IsChecked="True" Checked="Tab_Changed" ToolTip="Smart Editor">
                    <Path Data="M3,17.25V21H6.75L17.81,9.94L14.06,6.19M20.71,7.04C21.1,6.65 21.1,6.02 20.71,5.63L18.37,3.29C17.98,2.9 17.35,2.9 16.96,3.29L15.13,5.12L18.88,8.87L20.71,7.04Z" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" 
                          Stretch="Uniform" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </RadioButton>

                <RadioButton x:Name="TabRecolector" GroupName="MainMenu" Style="{StaticResource SidebarNavButtonStyle}" Checked="Tab_Changed" ToolTip="Recolector" Margin="0,10,0,0">
                    <Path Data="M19,3h-4.18C14.4,1.84,13.3,1,12,1S9.6,1.84,9.18,3H5C3.9,3,3,3.9,3,5v14c0,1.1,0.9,2,2,2h14c1.1,0,2-0.9,2-2V5 C21,3.9,20.1,3,19,3z M12,3c0.55,0,1,0.45,1,1s-0.45,1-1,1s-1-0.45-1-1S11.45,3,12,3z M17,17H7v-2h10V17z M17,13H7v-2h10V13z M17,9H7V7h10V9z" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" 
                          Stretch="Uniform" Width="15" Height="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </RadioButton>
            </StackPanel>
        </Border>

        <Grid x:Name="SidebarPanel" Grid.Column="1" Width="340" Margin="0,0,0,5" ClipToBounds="True">
            <Grid.CacheMode>
                <BitmapCache EnableClearType="True" RenderAtScale="1"/>
            </Grid.CacheMode>
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
            </Grid.ColumnDefinitions>

            <Grid x:Name="SidebarContentGrid" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> 
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="10,7,5,10" Height="25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="28"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#252B32" CornerRadius="4" BorderThickness="1" BorderBrush="#3A444D">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="25"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Path Data="M15.5,14H14.71L14.43,13.73C15.41,12.59 16,11.11 16,9.5A6.5,6.5 0 0,0 9.5,3A6.5,6.5 0 0,0 3,9.5A6.5,6.5 0 0,0 9.5,16C11.11,16 12.59,15.41 13.73,14.43L14,14.71V15.5L19,20.5L20.5,19L15.5,14M9.5,14C7,14 5,12 5,9.5C5,7 7,5 9.5,5C12,5 14,7 14,9.5C14,12 12,14 9.5,14Z" 
                                  Fill="{StaticResource TextMuted}" Stretch="Uniform" Margin="6" Width="12"/>
                            
                            <TextBox x:Name="TxtBusqueda" Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="White"
                                     VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11" CaretBrush="{StaticResource AccentColor}" 
                                     TextChanged="TxtBusqueda_TextChanged"/>
                        </Grid>
                    </Border>

                    <Button x:Name="BtnFiltro" Grid.Column="1" Click="BtnFiltro_Click" Style="{StaticResource SidebarIconButtonStyle}">
                        <Path Data="M14,12L10,8V5H11V3H5V5H6V8L2,12V14H14V12M7,5V8.5L4.5,11H11.5L9,8.5V5H7Z" 
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                              Stretch="Uniform" Height="12"/>
                    </Button>

                    <Popup x:Name="PopupFiltros" PlacementTarget="{Binding ElementName=BtnFiltro}" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" PreviewMouseWheel="PopupFiltros_PreviewMouseWheel">
                        <Border Background="#252B32" CornerRadius="8" BorderThickness="1" BorderBrush="#3A444D" Padding="0" Margin="0,5,0,0" ClipToBounds="True">
                            <StackPanel Width="220">
                                <Grid Height="190" Width="205" ClipToBounds="True" Background="#252B32">
                                    <Calendar x:Name="CalendarFiltro" 
                                              Style="{StaticResource EstiloCalendarioKaleb}" 
                                              SelectedDatesChanged="CalendarFiltro_SelectedDatesChanged" 
                                              Margin="-12,-2,-12,-8" 
                                              HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"
                                              BorderThickness="0"/>
                                </Grid>
                                <Border Padding="12,10,12,15">
                                    <StackPanel>
                                        <Separator Background="#3A444D" Margin="0,0,0,10"/>
                                        <TextBlock Text="TIPO DE CONTENIDO" Foreground="{StaticResource TextMuted}" FontSize="9" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <UniformGrid Columns="2">
                                            <CheckBox x:Name="ChkTexto" Content="Texto" Style="{StaticResource ModernSwitch}" IsChecked="True" Checked="Filtro_Changed" Unchecked="Filtro_Changed" Margin="0,0,0,8"/>
                                            <CheckBox x:Name="ChkCodigo" Content="Código" Style="{StaticResource ModernSwitch}" IsChecked="True" Checked="Filtro_Changed" Unchecked="Filtro_Changed" Margin="0,0,0,8"/>
                                            <CheckBox x:Name="ChkEnlace" Content="Enlaces" Style="{StaticResource ModernSwitch}" IsChecked="True" Checked="Filtro_Changed" Unchecked="Filtro_Changed"/>
                                            <Button Content="Limpiar" Click="LimpiarFiltros_Click" Background="Transparent" Foreground="{StaticResource AccentColor}" BorderThickness="0" FontSize="10" HorizontalAlignment="Left" Margin="0,2,0,0"/>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <Button x:Name="BtnCloseSidebar" Grid.Column="2" Click="ToggleSidebar_Click" Style="{StaticResource SidebarIconButtonStyle}">
                        <Path Data="M15 18L9 12L15 6Z" 
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                              Stretch="Uniform" Height="10"/>
                    </Button>
                </Grid>

                <TextBlock Grid.Row="1" Text="HISTORIAL" x:Name="TituloHistorial" FontFamily="Segoe UI" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="15,0,0,0"/>

                <ListBox x:Name="ListaClips" Grid.Row="2" Background="Transparent" BorderThickness="0" Padding="0" 
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                         ScrollViewer.ScrollChanged="ListaClips_ScrollChanged" 
                         SelectionChanged="ListaClips_SelectionChanged"
                         PreviewMouseDown="ListaClips_PreviewMouseDown" 
                         PreviewKeyDown="ListaClips_PreviewKeyDown"
                         FocusVisualStyle="{x:Null}" 
                         VirtualizingPanel.ScrollUnit="Pixel" 
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="CardBorder" Height="100" CornerRadius="8" Margin="5,0,10,12" Background="{StaticResource TextCardBg}" BorderThickness="1" BorderBrush="#1D2227">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>

                                    <Border x:Name="HeaderBg" Grid.Row="0" Background="#1A000000" CornerRadius="8,8,0,0" Padding="12,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock x:Name="TypeIcon" Text="[T]" Foreground="#A0AAB5" FontSize="12" FontWeight="Bold" Margin="0,0,6,0" FontFamily="Consolas" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="TypeName" Text="Text" Foreground="#A0AAB5" FontSize="12" FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center"/>

